  "keyFeatures": [
    "Private personal brain that can never be shared, by design",
    "Shared team brains with role-based access (Read / Write / Admin / Owner)",
    "Universal inbox — every capture lands there first, nothing files behind your back",
    "Automatic, Propose, and Off filing modes per brain",
    "Semantic search — find things by meaning, not just keywords",
    "MCP-based connections to Claude, Claude Code, ChatGPT, Cursor, and any MCP client",
    "Built-in filing skills for meetings, documents, conversations, and promoting to shared brains",
    "Granola integration for automatic meeting note capture",
    "Review queue for human oversight of uncertain filings",
    "Service credentials for unattended scripts and automations",
    "Webhook ingestion from third-party tools with HMAC guard rules",
    "Full version history — no edit ever loses content"
  ],
  "publicApiSurface": [
    "POST https://api.oncortex.ai/api/v1/inbox — push to default brain inbox",
    "GET https://api.oncortex.ai/api/v1/brains/{brainId}/inbox — list inbox items",
    "GET https://api.oncortex.ai/api/v1/brains/{brainId}/inbox/{itemId} — get one item",
    "POST https://api.oncortex.ai/api/v1/brains/{brainId}/inbox — upload item to brain",
    "PUT https://api.oncortex.ai/api/v1/brains/{brainId}/inbox/{itemId}/status — update item status",
    "POST https://api.oncortex.ai/api/v1/brains/{brainId}/inbox/{itemId}/archive — archive item",
    "POST https://api.oncortex.ai/api/ingest/{brainId} — webhook ingestion endpoint",
    "MCP endpoint: https://api.oncortex.ai/mcp/{brainId} — streamable HTTP MCP server per brain",
    "Service credentials (ck_ bearer tokens) — scoped read or read-write keys for automation"
  ]
}
